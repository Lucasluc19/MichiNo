# ─── Base de données ───────────────────────────────
MONGODB_URI=mongodb+srv://admin:VOTRE_MOT_DE_PASSE@cluster0.xxxxx.mongodb.net/michino

# ─── Cloudinary (stockage médias) ─────────────────
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ─── Authentification ─────────────────────────────
JWT_SECRET=CHANGEZ_CECI_PAR_64_CARACTERES_ALEATOIRES_MINIMUM
ADMIN_USERNAME=votre_nom_admin
ADMIN_PASSWORD=MotDePasseComplexe123!@#

# ─── SEO IA (Anthropic Claude) ────────────────────
# Obtenez votre clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-votre_cle_anthropic

# ─── Site (pour sitemap + Open Graph) ─────────────
SITE_URL=https://votre-site.onrender.com

# ─── Environnement ────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Tag Vocal IA (ElevenLabs) ────────────────────
# Obtenez votre clé sur https://elevenlabs.io
# Sans clé : un jingle musical est généré automatiquement
ELEVENLABS_API_KEY=sk_votre_cle_elevenlabs
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
VOCAL_TAG_TEXT=MichiNo
VOCAL_TAG_POSITION=intro

# ─── Push Notifications (VAPID) ───────────────────────────────
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2))"
# Puis copier les valeurs ci-dessous (VAPID_PUBLIC_KEY commence par "BN...")
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@michino.com

# ─── Email / Newsletter (SMTP) ─────────────────────────────────
# Sans config : les emails sont simulés (log console uniquement)
# Compatible Gmail, Brevo, Mailgun, Resend, etc.
# Exemple Gmail : SMTP_HOST=smtp.gmail.com SMTP_PORT=587
# Exemple Brevo : SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MichiNo- <noreply@michino.com>
